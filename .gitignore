# ═══════════════════════════════════════════════════════════════════
#  CreConnect — Root .gitignore
#  Covers: Node.js backend, React/Vite frontend, AI recommender module
# ═══════════════════════════════════════════════════════════════════


# ── Dependencies ────────────────────────────────────────────────────
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/install-state.gz


# ── Environment variables (NEVER commit real secrets) ───────────────
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
**/.env
**/.env.local
**/.env.development
**/.env.production
**/.env.staging
**/.env.test

# Keep the example file — it documents required variables
!.env.example
!**/.env.example


# ── Build outputs ────────────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
**/dist/
**/build/


# ── Uploaded user files (store in cloud storage in production) ───────
creconnect-backend/uploads/avatars/*
creconnect-backend/uploads/banners/*
creconnect-backend/uploads/creator-media/*

# Keep the folder structure
!creconnect-backend/uploads/avatars/.gitkeep
!creconnect-backend/uploads/banners/.gitkeep
!creconnect-backend/uploads/creator-media/.gitkeep


# ── Logs ─────────────────────────────────────────────────────────────
*.log
*.err
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
creconnect-react/backend.log
creconnect-react/backend.err
creconnect-react/frontend.log
creconnect-react/frontend.err


# ── Runtime / cache ──────────────────────────────────────────────────
.cache/
.parcel-cache/
.vite/
**/.vite/
.turbo/
.eslintcache
*.tsbuildinfo


# ── Test & coverage ──────────────────────────────────────────────────
coverage/
**/coverage/
.nyc_output/
*.lcov


# ── OS generated files ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# ── IDE / editor ─────────────────────────────────────────────────────
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# VS Code — ignore local workspace settings but keep shared config
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
# Keep: .vscode/extensions.json (shared team extensions)


# ── Claude Code (AI assistant local session data) ────────────────────
.claude/


# ── Docker (keep compose files, ignore local overrides) ──────────────
docker-compose.override.yml
docker-compose.local.yml


# ── Sequelize / database ─────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
database/dumps/
database/backups/


# ── Temporary / scratch files ─────────────────────────────────────────
*.tmp
*.temp
*.bak
*.swp
*~
tmp/
temp/
